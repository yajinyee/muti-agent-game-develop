{
  "enabled": true,
  "name": "Auto Git Push",
  "description": "每次 Kiro agent 停止後，自動 commit 並 push 最新進度到 GitHub",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -ExecutionPolicy Bypass -File \"d:\\Kiro\\tools\\git_push.ps1\" \"chore: auto update progress\"",
    "timeout": 120
  }
}